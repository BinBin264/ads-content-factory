# Option A: one line with comma-separated keys.
GEMINI_API_KEYS=your_first_gemini_api_key,your_second_gemini_api_key

# Option B: indexed keys. You can use this instead of GEMINI_API_KEYS.
# GEMINI_API_KEY_1=your_first_gemini_api_key
# GEMINI_API_KEY_2=your_second_gemini_api_key

# Legacy one-key setup is still supported.
# GEMINI_API_KEY=your_gemini_api_key

# The backend rotates keys per request and retries the next key on
# quota/rate-limit/auth/provider errors.
GEMINI_MODEL=gemini-2.5-flash

VIDEO_PROVIDER_NAME=
VIDEO_PROVIDER_API_KEY=
