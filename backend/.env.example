# Option A: one line with comma-separated keys.
GEMINI_API_KEYS=your_first_gemini_api_key,your_second_gemini_api_key

# Option B: indexed keys. You can use this instead of GEMINI_API_KEYS.
# GEMINI_API_KEY_1=your_first_gemini_api_key
# GEMINI_API_KEY_2=your_second_gemini_api_key

# Legacy one-key setup is still supported.
# GEMINI_API_KEY=your_gemini_api_key

# The backend rotates keys per request and retries the next key on
# quota/rate-limit/auth/provider errors.
GEMINI_MODEL=gemini-2.5-flash
# One Gemini attempt may take longer for multimodal Plan Creation.
GEMINI_REQUEST_TIMEOUT_SECONDS=180
# Timeout, 5xx, and network failures retry with another rotating key.
GEMINI_TRANSIENT_MAX_ATTEMPTS=2
GEMINI_RETRY_BASE_SECONDS=1.5

# ShopAIKey image generation for character/location references and storyboard
# keyframes. This credential is also reused for video by default.
IMAGE_PROVIDER_NAME=shopaikey-google
IMAGE_PROVIDER_API_KEY=your_shopaikey_api_key
IMAGE_PROVIDER_BASE_URL=https://api.shopaikey.com
# Automation mode must send the selected image model with every generation job.
IMAGE_OUTPUT_SIZE=2K
IMAGE_GENERATION_CONCURRENCY=2
# Number of retries after the initial request. HTTP 524 is retryable.
IMAGE_GENERATION_MAX_RETRIES=3
IMAGE_GENERATION_RETRY_BASE_SECONDS=2

# ShopAIKey video generation. Set VIDEO_PROVIDER_API_KEY only when video uses
# a different ShopAIKey credential from IMAGE_PROVIDER_API_KEY.
VIDEO_PROVIDER_NAME=shopaikey
# VIDEO_PROVIDER_API_KEY=your_optional_dedicated_shopaikey_key
VIDEO_PROVIDER_BASE_URL=https://api.shopaikey.com
VIDEO_MODEL_ID=veo3.1-pro
# Phase 3 can override this default per request with: veo3.1-pro,
# veo3.1-fast, grok-video-3, or grok-video-3-10s.
VIDEO_MODEL_RATIO=9:16
# Keep false so ShopAIKey does not rewrite the production prompt.
VIDEO_ENHANCE_PROMPT=false
VIDEO_ENABLE_UPSAMPLE=true
VIDEO_REFERENCE_LIMIT=1
VIDEO_REQUEST_TIMEOUT_SECONDS=90
