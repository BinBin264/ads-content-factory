# Option A: one line with comma-separated keys.
GEMINI_API_KEYS=your_first_gemini_api_key,your_second_gemini_api_key

# Option B: indexed keys. You can use this instead of GEMINI_API_KEYS.
# GEMINI_API_KEY_1=your_first_gemini_api_key
# GEMINI_API_KEY_2=your_second_gemini_api_key

# Legacy one-key setup is still supported.
# GEMINI_API_KEY=your_gemini_api_key

# The backend rotates keys per request and retries the next key on
# quota/rate-limit/auth/provider errors.
GEMINI_MODEL=gemini-2.5-flash

# Optional image provider hook for character/location/keyframe generation.
# Must be OpenAI-compatible /v1/images/generations.
# IMAGE_PROVIDER_NAME=openai-compatible
# IMAGE_PROVIDER_API_KEY=your_image_provider_key
# IMAGE_PROVIDER_BASE_URL=https://api.openai.com/v1
# IMAGE_MODEL_ID=gpt-image-1

# Optional video provider hook for 79AI/Gommo VEO Omni Flash ingredients.
# Current backend does not fake video output.
# VIDEO_PROVIDER_NAME=79ai
# VIDEO_PROVIDER_API_KEY=your_79ai_access_token
# VIDEO_PROVIDER_BASE_URL=https://api.gommo.net
# VIDEO_PROVIDER_DOMAIN=79ai.net
# VIDEO_MODEL_ID=veo_omni
# VIDEO_MODEL_MODE=flash
# VIDEO_MODEL_RATIO=9:16
# VIDEO_MODEL_DURATION=4
# VIDEO_MODEL_RESOLUTION=720p
# VIDEO_TRANSLATE_TO_EN=false
# VIDEO_REFERENCE_LIMIT=4
# VIDEO_POLL_INTERVAL_SECONDS=3.5
# VIDEO_POLL_TIMEOUT_SECONDS=160
